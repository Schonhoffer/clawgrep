{
  "name": "clawgrep",
  "version": "0.1.2",
  "description": "Grep-like CLI with hybrid semantic and keyword search",
  "main": "index.js",
  "types": "index.d.ts",
  "bin": {
    "clawgrep": "./cli.js"
  },
  "napi": {
    "name": "clawgrep",
    "triples": {
      "defaults": true,
      "additional": [
        "aarch64-apple-darwin",
        "aarch64-unknown-linux-gnu"
      ]
    }
  },
  "license": "(MIT OR Apache-2.0)",
  "repository": {
    "type": "git",
    "url": "https://github.com/Schonhoffer/clawgrep"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "cli.js",
    "README.md"
  ],
  "devDependencies": {
    "@napi-rs/cli": "^2.18.0"
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --platform --release",
    "version": "napi version"
  },
  "optionalDependencies": {
    "@clawgrep/clawgrep-win32-x64-msvc": "0.1.2",
    "@clawgrep/clawgrep-darwin-x64": "0.1.2",
    "@clawgrep/clawgrep-linux-x64-gnu": "0.1.2",
    "@clawgrep/clawgrep-darwin-arm64": "0.1.2",
    "@clawgrep/clawgrep-linux-arm64-gnu": "0.1.2"
  }
}