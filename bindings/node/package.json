{
  "name": "clawgrep",
  "version": "0.1.0",
  "description": "Like grep with semantic search, for ai agents",
  "main": "index.js",
  "types": "index.d.ts",
  "bin": {
    "clawgrep": "./cli.js"
  },
  "napi": {
    "name": "clawgrep",
    "triples": {
      "defaults": true,
      "additional": [
        "aarch64-apple-darwin",
        "aarch64-unknown-linux-gnu",
        "aarch64-pc-windows-msvc"
      ]
    }
  },
  "license": "(MIT OR Apache-2.0)",
  "repository": {
    "type": "git",
    "url": "https://github.com/Schonhoffer/clawgrep"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "cli.js"
  ],
  "devDependencies": {
    "@napi-rs/cli": "^2.18.0"
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --platform --release",
    "prepublishOnly": "napi prepublish -t npm",
    "version": "napi version"
  }
}
